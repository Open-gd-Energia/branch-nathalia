# URL base da API (backend). Em desenvolvimento local use o endereço do backend na sua máquina.
# Backend Spring Boot padrão: server.port=8080
NEXT_PUBLIC_API_URL=http://localhost:8080

# (Opcional) Quando o front roda em Docker, o servidor Next.js precisa alcançar o backend pela rede interna.
# Use o nome do serviço do backend: API_URL_SERVER=http://backend:8080 (já definido no docker-compose).
# API_URL_SERVER=

# URL do frontend (onde o Next.js está rodando). Em dev: http://localhost:3000
# No backend (application.properties) configure: opengd.url.frontend=http://localhost:3000 (ou http://127.0.0.1:3000) para CORS.
NEXTAUTH_URL=http://localhost:3000

# Chave secreta para sessões NextAuth (gere com: openssl rand -base64 32)
NEXTAUTH_SECRET=
